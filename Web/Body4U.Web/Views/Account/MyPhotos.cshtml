@model List<Body4U.Web.ViewModels.Account.MyPhotosViewModel>

@using System.Security.Claims

<section class="d-flex align-items-center">
    <div class="wrapper d-flex align-items-stretch">
        <partial name="_MyProfilePartial" model="User.Claims.FirstOrDefault(x=>x.Type == ClaimTypes.NameIdentifier)?.Value" />
        <div id="content" class="p-4 p-md-5">
            <div class="show-hide-sidebar">
                <button type="button" id="sidebarCollapse" class="btn btn-primary">
                    <i class="fa fa-bars"></i>
                    <span class="sr-only">Toggle Menu</span>
                </button>
            </div>
            <div class="img-collection">
                @if (Model.Count() > 0)
                {
                    @foreach (var item in Model)
                    {
                        <div class="img-item">
                            <img src="data:image;base64,@item.Photo" class="img-src" alt="">
                            <form method="post">
                                <button type="submit" class="btn btn-danger" asp-area="" asp-controller="Trainer" asp-action="DeletePhoto" asp-route-id="@item.Id" onclick="return confirm('Сигурни ли сте, че искате, да изтриете тази снимка?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                        @*<img src="data:image;base64,@item.Photo" class="img-element" alt="">
                            <form method="post">
                                <button type="submit" class="btn btn-danger" asp-area="" asp-controller="Trainer" asp-action="DeletePhoto" asp-route-id="@item.Id" onclick="return confirm('Сигурни ли сте, че искате, да изтриете тази снимка?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>*@
                        @*<img src="data:image;base64,@item.Photo" class="img-fluid" alt="...">*@
                        <!--<div class="col-lg-4 col-sm-6">-->
                        @*<span class="closes" title="Delete">&times;</span>*@
                        @*<img src="data:image;base64,@item.Photo" alt="" style="max-height: 357.36px" class="single_gallery_part">*@
                        <!--<a href="data:image;base64,@item.Photo" class="single_gallery_part">
                                <img src="data:image;base64,@item.Photo" style="max-height: 357.36px" alt="">
                            </a>
                            <form method="post">
                                <button type="submit" class="btn btn-danger" asp-area="" asp-controller="Trainer" asp-action="DeletePhoto" asp-route-id="@item.Id" onclick="return confirm('Сигурни ли сте, че искате, да изтриете тази снимка?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>-->
                    }
                }
                else
                {
                    <h1>Все още няма качени снимки.</h1>
                }
            </div>
        </div>
    </div>
</section>