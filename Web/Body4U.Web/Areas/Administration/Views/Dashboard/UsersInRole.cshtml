@model Body4U.Web.Areas.Administration.ViewModels.UsersInRoleViewModel

<div class="container">
    <form method="post" class="mt-3">
        <div class="card">
            <div class="card-header">
                <h3>Потребители в тази роля</h3>
            </div>
            <div class="card-body">
                @if (Model.Users.Any())
                {
                    foreach (var user in Model.Users)
                    {
                        <h5 class="card-title">@user</h5>
                    }
                }
                else
                {
                    <h5 class="card-title">Няма потребители в тази роля</h5>
                }
            </div>
            <div class="card-footer">
                <a asp-area="Administration" asp-controller="Dashboard" asp-action="EditUsersInRole"
                   asp-route-roleId="@Model.Id" class="btn btn-primary">
                    Добави или премахни
                </a>
                <a asp-action="GetRoles" class="btn btn-primary" style="width:auto">Отказ</a>
            </div>
        </div>
    </form>

